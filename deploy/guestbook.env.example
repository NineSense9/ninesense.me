# Copy to /etc/ninesense/guestbook.env, replace every REPLACE_* value,
# then set owner root:ninesense and mode 0640.
NINESENSE_DATABASE_URL=sqlite:////var/lib/ninesense/guestbook.sqlite3
NINESENSE_CONTACT_KEY=REPLACE_WITH_URLSAFE_BASE64_32_BYTE_KEY
NINESENSE_SECURITY_KEY=REPLACE_WITH_DIFFERENT_URLSAFE_BASE64_32_BYTE_KEY
NINESENSE_SESSION_PEPPER=REPLACE_WITH_LONG_RANDOM_SESSION_PEPPER
NINESENSE_RATE_LIMIT_KEY=REPLACE_WITH_LONG_RANDOM_RATE_LIMIT_KEY
NINESENSE_COOKIE_SECURE=false
NINESENSE_COOKIE_NAME=ninesense_admin
NINESENSE_SESSION_HOURS=8
NINESENSE_LOGIN_CHALLENGE_MINUTES=5
NINESENSE_SMTP_HOST=REPLACE_WITH_SMTP_HOST
NINESENSE_SMTP_PORT=465
NINESENSE_SMTP_USERNAME=REPLACE_WITH_SMTP_ACCOUNT
NINESENSE_SMTP_PASSWORD=REPLACE_WITH_SMTP_APP_PASSWORD
NINESENSE_NOTIFICATION_TO=REPLACE_WITH_NOTIFICATION_EMAIL
NINESENSE_PUBLIC_ADMIN_URL=https://ninesense.me/admin/
